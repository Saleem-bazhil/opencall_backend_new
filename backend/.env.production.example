# Production runtime variables for the API process.
NODE_ENV=production
PORT=4000
DATABASE_URL=postgres://opencall:replace-with-password@postgres:5432/opencall
JWT_ACCESS_SECRET=replace-with-32-plus-character-random-secret
UPLOAD_DIR=/app/storage/uploads
CORS_ORIGIN=https://opencall.example.com
ADMIN_COOKIE_SECRET=replace-with-32-plus-character-random-secret
ADMIN_SESSION_SECRET=replace-with-32-plus-character-random-secret
