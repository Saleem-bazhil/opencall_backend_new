# Copy to .env in the repo root for production Docker Compose deploys.
POSTGRES_DB=opencall
POSTGRES_USER=opencall
POSTGRES_PASSWORD=replace-with-strong-production-postgres-password

JWT_ACCESS_SECRET=replace-with-32-plus-character-random-secret
ADMIN_COOKIE_SECRET=replace-with-32-plus-character-random-secret
ADMIN_SESSION_SECRET=replace-with-32-plus-character-random-secret

# Use the public HTTPS frontend origin. Add more origins as comma-separated values if required.
CORS_ORIGIN=https://opencall.example.com

API_PORT=4000

# Required only when using docker-compose.proxy.yml.
API_DOMAIN=api.opencall.example.com
ACME_EMAIL=admin@example.com
HTTP_PORT=80
HTTPS_PORT=443
MAX_UPLOAD_SIZE=80MB

POSTGRES_MEM_LIMIT=1g
POSTGRES_CPUS=1.0
API_MEM_LIMIT=1536m
API_CPUS=1.5
CADDY_MEM_LIMIT=256m
CADDY_CPUS=0.5
