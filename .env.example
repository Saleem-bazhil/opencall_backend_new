# Docker Compose reads this file when copied to .env in the repo root.
POSTGRES_DB=opencall
POSTGRES_USER=opencall
POSTGRES_PASSWORD=opencall_local_password

# Local-only API runtime secrets. Replace for any shared environment.
JWT_ACCESS_SECRET=local-dev-jwt-secret-0000000000000000
ADMIN_COOKIE_SECRET=local-dev-admin-cookie-secret-0000000000
ADMIN_SESSION_SECRET=local-dev-admin-session-secret-000000000

# Comma-separated frontend origins allowed to call the API.
CORS_ORIGIN=http://localhost:3000

# Local published API port for docker compose.
API_PORT=4000

# Optional API reverse proxy settings for docker-compose.proxy.yml.
API_DOMAIN=api.opencall.example.com
ACME_EMAIL=admin@example.com
HTTP_PORT=80
HTTPS_PORT=443
MAX_UPLOAD_SIZE=80MB

# Optional container resource limit overrides.
POSTGRES_MEM_LIMIT=1g
POSTGRES_CPUS=1.0
API_MEM_LIMIT=1536m
API_CPUS=1.5
CADDY_MEM_LIMIT=256m
CADDY_CPUS=0.5
